## 4. PIR センサー（AM312）実装規約

### 4.1 ハードウェア前提

- 採用センサー: **AM312**（小型 PIR モジュール）
- 接続: `PIR_PIN = GPIO 27`（`config.h` で定義）
- 電源: 3.3V または 5V 給電可
- ホールド時間: **約 2 秒固定**（ハードウェアで調整不可）→ 「人がいる」状態の継続判定は ESP32 側ソフトタイマー（`AUTO_OFF_MS` 既定 5 分）で行う
- **ウォームアップ:** 電源投入後 **60 秒間（`PIR_WARMUP_MS = 60000`）は PIR 入力を無視** すること。AM312 はウォームアップ中に誤検知を出すため、これを守らないと起動直後に意図せず点灯する。

### 4.2 ✅ Good Example: 割り込み駆動 + loop での評価（省電力版）

```cpp
const unsigned long AUTO_OFF_MS    = 5UL * 60UL * 1000UL;
const unsigned long PIR_WARMUP_MS  = 60UL * 1000UL;
const unsigned long PIR_DEDUP_MS   = 1000UL;

static volatile unsigned long pirLastIsrAt = 0;  // ISR で時刻のみ記録
static volatile bool          pirRiseFlag = false;

static unsigned long bootAt        = 0;
static unsigned long lastMotionAt  = 0;
static bool          ledIsOn       = false;

void IRAM_ATTR onPirIsr() {
  pirLastIsrAt = millis();
  pirRiseFlag  = true;            // フラグ立てだけ。重い処理は loop で。
}

void setupPir() {
  pinMode(PIR_PIN, INPUT);
  bootAt = millis();
  attachInterrupt(digitalPinToInterrupt(PIR_PIN), onPirIsr, RISING);
}

void handlePir() {
  unsigned long now = millis();

  // ① ウォームアップ中はフラグを捨てる
  if (now - bootAt < PIR_WARMUP_MS) {
    pirRiseFlag = false;
    return;
  }

  // ② 立ち上がりエッジ処理（ISR からのフラグ）
  if (pirRiseFlag) {
    pirRiseFlag = false;          // 即クリア（次の割り込みを取りこぼさない）

    if (currentMode != Mode::AUTO) {
      Serial.println("[PIR] HIGH ignored (mode != AUTO)");
    } else {
      bool isNewEvent = (now - lastMotionAt > PIR_DEDUP_MS);
      lastMotionAt = now;

      // 自動点灯: 消灯中の新規イベントだけ WLED に POST
      if (!ledIsOn && isNewEvent) {
        applyDefaultScene();      // WLED /json/state に PIR_DEFAULT_* を POST
        ledIsOn = true;
        Serial.println("[PIR] motion -> LED ON");
        publishState("PIR_ON");
      }
      // 点灯中の再トリガは lastMotionAt 更新のみ
    }
  }

  // ③ 自動消灯タイマー（loop で 1 秒粒度で判定すれば十分）
  if (ledIsOn && currentMode == Mode::AUTO &&
      now - lastMotionAt > AUTO_OFF_MS) {
    applyOff();                   // WLED /json/state に {"on": false}
    ledIsOn = false;
    Serial.printf("[PIR] timeout %lums -> LED OFF\n", AUTO_OFF_MS);
    publishState("PIR_OFF");
  }
}
```

### 4.3 ❌ Bad Example

```cpp
// 悪い例 1: ISR で WLED API を叩く（WiFi/MQTT スタックと衝突して再起動する）
void IRAM_ATTR onPirIsr() {
  applyDefaultScene();   // ← HTTP は loop でやれ
  Serial.println("...");  // ← Serial も loop でやれ
}

// 悪い例 2: AUTO 以外でも PIR で勝手に LED を点ける（MANUAL/STANDBY を破壊する）
void handlePir() {
  if (pirRiseFlag) { applyDefaultScene(); }  // ← モード判定なし
}

// 悪い例 3: ウォームアップを考慮しない（電源投入直後に誤点灯）
void handlePir() {
  if (pirRiseFlag) applyDefaultScene();
  // → AM312 は起動 60 秒以内に誤検知を出す
}

// 悪い例 4: 自動消灯時に色・エフェクトまで上書きする（次回点灯時に余計な状態同期が必要）
void applyOff() {
  body["on"] = false;
  body["bri"] = 0;                       // ← 不要
  body["seg"][0]["col"][0][0] = 0;       // ← 不要
  body["seg"][0]["fx"] = 0;              // ← 不要
}
```

