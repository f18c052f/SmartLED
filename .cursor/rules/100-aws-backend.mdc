## 5. Alexa インテント設計

Custom Skill 内で以下 3 つのインテントをサポートする。Smart Home Skill への移行は将来課題。

| インテント | 用途 | 振る舞い |
|------------|------|----------|
| `LightControlIntent` | 自然言語によるシーン指定 | Gemini → `smartled/esp32/control` へ publish + `mode=MANUAL` を `smartled/esp32/mode` へ publish |
| `PowerOnIntent`  | 「ライトをつけて」「自動にして」 | `smartled/esp32/mode` に `{"mode":"AUTO"}` を publish（control へは publish しない） |
| `PowerOffIntent` | 「ライトを消して」「電気を消して」 | `smartled/esp32/mode` に `{"mode":"STANDBY"}` を publish |

#### ✅ Good Example: インテントごとの分岐とトピック振り分け

```typescript
type AlexaCommand =
  | { kind: "scene"; phrase: string }
  | { kind: "powerOn" }
  | { kind: "powerOff" }
  | { kind: "unknown" };

export function classifyAlexaIntent(event: AlexaRequest): AlexaCommand {
  const intentName = event?.request?.intent?.name;
  switch (intentName) {
    case "PowerOnIntent":  return { kind: "powerOn" };
    case "PowerOffIntent": return { kind: "powerOff" };
    case "LightControlIntent": {
      const phrase = extractNaturalLanguageFromAlexa(event);
      return phrase ? { kind: "scene", phrase } : { kind: "unknown" };
    }
    default: return { kind: "unknown" };
  }
}

// handler 内
const cmd = classifyAlexaIntent(event);
switch (cmd.kind) {
  case "powerOn":
    await publishMode("AUTO");
    return buildAlexaResponse("はい、ライトを自動にしました。");
  case "powerOff":
    await publishMode("STANDBY");
    return buildAlexaResponse("はい、ライトを消しました。");
  case "scene":
    const ledParams = await fetchLedParams(cmd.phrase, apiKey);
    await publishControl(ledParams);
    await publishMode("MANUAL"); // シーン指定は MANUAL 確定（PIR を停止）
    return buildAlexaResponse("はい、照明を調整しました。");
  case "unknown":
    return buildAlexaResponse("すみません、うまく聞き取れませんでした。");
}
```

#### ❌ Bad Example

```typescript
// 悪い例: 全リクエストを LightControlIntent と仮定して Gemini に投げる
//         「消して」のような単純命令でも Gemini を叩いてしまい、料金・遅延・誤動作の原因になる
const phrase = extractNaturalLanguageFromAlexa(event);
const ledParams = await fetchLedParams(phrase, apiKey);
await publishControl(ledParams);
```

