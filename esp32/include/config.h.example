#pragma once

// このファイルを esp32/include/config.h にコピーして実際の値を設定してください。
// config.h は .gitignore で追跡対象外です。

// =============================================================================
// WiFi 設定
// =============================================================================
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// =============================================================================
// AWS IoT Core 設定
// =============================================================================
// IoT エンドポイントの確認コマンド:
//   aws iot describe-endpoint --endpoint-type iot:Data-ATS --region ap-northeast-1 --query endpointAddress --output text
#define AWS_IOT_ENDPOINT  "xxxxxxxxxxxx-ats.iot.ap-northeast-1.amazonaws.com"
#define AWS_IOT_PORT      8883
#define AWS_IOT_CLIENT_ID "smartled-esp32"

// MQTT keepalive（秒）。AWS IoT は最大 1200 秒許容。省電力のため 60 秒推奨。
#define MQTT_KEEPALIVE_SEC 60

// =============================================================================
// MQTT トピック（requirements.md §9 / .cursor/rules/000-agent-domain.mdc 参照）
// =============================================================================
#define MQTT_TOPIC_CONTROL "smartled/esp32/control" // Lambda → ESP32: シーン指定
#define MQTT_TOPIC_MODE    "smartled/esp32/mode"    // Lambda → ESP32: モード遷移
#define MQTT_TOPIC_STATE   "smartled/esp32/state"   // ESP32 → Lambda: 状態通知

// =============================================================================
// WLED 設定
// =============================================================================
// WLED が動作している ESP32 の IP アドレス（同一 LAN 上）
#define WLED_IP         "192.168.x.x"
#define WLED_PORT       80
#define WLED_HTTP_TIMEOUT_MS 3000

// ABL 上限（mA）。requirements.md §4。4250 を超えないこと。
#define WLED_ABL_MAX_MILLIAMPS 4250
// 1: WiFi 接続直後に POST /json/cfg で hw.led.maxpwr を同期（sv=false・RAM のみ）
#define WLED_SYNC_ABL_ON_BOOT  1

// =============================================================================
// GPIO 割り当て（requirements.md §8.0 で公式に指定）
// =============================================================================
// AM312 PIR センサー出力（INPUT）
#define PIR_PIN       27
// プッシュスイッチ（INPUT_PULLUP、押下で LOW）
#define MODE_BTN_PIN  13

// =============================================================================
// PIR センサー（AM312）タイマー設定（requirements.md §8.3）
// =============================================================================
// AM312 ウォームアップ時間。起動から 60 秒は PIR 入力を完全無視（誤検知抑止）
#define PIR_WARMUP_MS         (60UL * 1000UL)
// 1 秒以内の連続立ち上がりエッジは同一イベントとみなしタイマーリセットのみ
#define PIR_DEDUP_MS          1000UL
// 無人タイマー: 最終 HIGH 検出からこの時間 LOW が続いたら自動消灯（既定 5 分）
#define AUTO_OFF_MS           (5UL * 60UL * 1000UL)

// PIR 検知時に WLED に送信する既定シーン（暖色 80% Solid）
#define PIR_DEFAULT_COLOR_R       0xFF
#define PIR_DEFAULT_COLOR_G       0xA8
#define PIR_DEFAULT_COLOR_B       0x4A
#define PIR_DEFAULT_BRIGHTNESS    204    // 80% (= 255 * 0.8)
#define PIR_DEFAULT_EFFECT_ID     0      // WLED Solid

// =============================================================================
// プッシュスイッチタイマー設定（requirements.md §8.2）
// =============================================================================
#define BTN_DEBOUNCE_MS    30UL
#define BTN_LONG_PRESS_MS  2000UL
#define BTN_SHORT_MIN_MS   50UL

// =============================================================================
// メインループ設計
// =============================================================================
// loop() 周期。10ms ポーリングは禁止（省電力規約）。
#define LOOP_INTERVAL_MS   100UL
// MQTT 再接続のリトライ間隔
#define MQTT_RECONNECT_INTERVAL_MS 5000UL
