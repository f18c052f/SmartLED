#pragma once

// このファイルを esp32/include/config.h にコピーして実際の値を設定してください。
// config.h は .gitignore で追跡対象外です。

// ----- WiFi 設定 -----
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// ----- AWS IoT Core 設定 -----
// IoT エンドポイントの確認コマンド:
//   aws iot describe-endpoint --endpoint-type iot:Data-ATS --region ap-northeast-1 --query endpointAddress --output text
#define AWS_IOT_ENDPOINT  "xxxxxxxxxxxx-ats.iot.ap-northeast-1.amazonaws.com"
#define AWS_IOT_PORT      8883
#define AWS_IOT_CLIENT_ID "smartled-esp32"

// ----- MQTT トピック -----
#define MQTT_TOPIC_SUBSCRIBE "smartled/esp32/control"

// ----- WLED 設定 -----
// WLED が動作している ESP32 の IP アドレス（同一 LAN 上）
#define WLED_IP   "192.168.x.x"
#define WLED_PORT 80
