#pragma once

// このファイルを esp32/secrets/certs.h にコピーし、SSM から取得した証明書を貼り付けてください。
// secrets/certs.h は .gitignore で追跡対象外です。
//
// 証明書の取得コマンド（要: AWS CLI 設定済み）:
//
//   # 証明書 PEM
//   aws ssm get-parameter --name /smartled/iot/cert-pem \
//     --region ap-northeast-1 --query Parameter.Value --output text
//
//   # 秘密鍵（SecureString のため --with-decryption が必要）
//   aws ssm get-parameter --name /smartled/iot/private-key \
//     --with-decryption --region ap-northeast-1 --query Parameter.Value --output text
//
//   # ルート CA（AWS の公開ページからダウンロード）
//   curl https://www.amazontrust.com/repository/AmazonRootCA1.pem

// ルート CA 証明書 (Amazon Root CA 1)
const char AWS_CERT_CA[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
<ここに AmazonRootCA1.pem の内容を貼り付け>
-----END CERTIFICATE-----
)EOF";

// デバイス証明書 PEM (/smartled/iot/cert-pem の値)
const char AWS_CERT_CRT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
<ここに cert-pem の内容を貼り付け>
-----END CERTIFICATE-----
)EOF";

// デバイス秘密鍵 (/smartled/iot/private-key の値)
const char AWS_CERT_PRIVATE[] PROGMEM = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
<ここに private-key の内容を貼り付け>
-----END RSA PRIVATE KEY-----
)EOF";
